# ── Secrets — NEVER commit these ──────────────────────────────────────────────
.env
*.key
*.pem
nginx/.htpasswd
# ── Runtime data ──────────────────────────────────────────────────────────────
data/
logs/
*.db
*.db-journal
*.db-wal
*.db-shm

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Docker build vendoring ────────────────────────────────────────────────────
# `npm run docker:prep` copies escrow-core here for the Docker build context.
# Never commit a copy of the money library (avoids drift — escrow-core is its
# own pinned repo). Bare-metal deploys don't use this at all.
vendor/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor files ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# --------Nostr fed plans -------
#NOSTR-DESIGN.md
#v4call-nostr-gate/

# that thing, server signing thingly 
public/.well-known/v4call-server.json

# noob-docs
noob-docs/

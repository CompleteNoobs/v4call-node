# ═══════════════════════════════════════════════════════════════════════════════
# v4call Server Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
#
# Lines starting with # are comments — they are ignored.
# Do NOT put quotes around values unless they contain spaces.
# Do NOT commit your .env file to git — it contains private keys!
# ═══════════════════════════════════════════════════════════════════════════════


# ── Your Server Brand ─────────────────────────────────────────────────────────
# This is the name shown in the UI and used in on-chain posts.
# Change these to your own brand if you are forking v4call.
SERVER_NAME=v4call
SERVER_DOMAIN=v4call.com

# Your server's Hive account (receives platform fees)
# This account will post the server identity on-chain (future federation feature)
SERVER_HIVE_ACCOUNT=v4call


# ── Escrow Account ────────────────────────────────────────────────────────────
# The Hive account that holds caller funds during calls.
# Must be a real Hive account you control.
ESCROW_ACCOUNT=v4call-escrow

# The ACTIVE private key for the escrow account.
# ⚠️  KEEP THIS SECRET — anyone with this key can drain the escrow account.
# ⚠️  Never commit this to git or share it publicly.
# The active key starts with 5K or 5J (not the posting key).
V4CALL_ESCROW_KEY=5Kxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Platform Fees ─────────────────────────────────────────────────────────────
# Default platform fee percentage taken from each call.
# Users can override this in their own v4call-rates post.
# Example: 10 = 10%, 5 = 5%, 0 = no platform fee
DEFAULT_PLATFORM_FEE=10


# ── Admin Access ──────────────────────────────────────────────────────────────
# Secret key to access /admin/ledger and /admin/balance endpoints.
# Choose a long random string — treat it like a password.
# Example: openssl rand -hex 32
ADMIN_KEY=change-me-to-a-long-random-secret-string


# ── Network ───────────────────────────────────────────────────────────────────
# Port the Node.js server listens on internally.
# Nginx (or your reverse proxy) forwards public traffic to this port.
PORT=3000

# Host to bind to. Use 127.0.0.1 when behind Nginx (recommended).
# Use 0.0.0.0 only if you want direct access without a reverse proxy.
BIND_HOST=127.0.0.1


# ── Hive API ──────────────────────────────────────────────────────────────────
# Primary Hive API node. The server automatically falls back to other nodes
# if this one is slow or down.
HIVE_API=https://api.hive.blog


# ── Call Behaviour ────────────────────────────────────────────────────────────
# Cooldown in milliseconds between free call attempts to the same callee.
# Prevents spam-ringing. Default: 30000 (30 seconds)
CALL_COOLDOWN_MS=30000

# Maximum call duration in minutes. Server will auto-end the call at this limit.
# Default: 120 (2 hours)
MAX_CALL_DURATION_MIN=120

# How many times to retry Hive payment verification before giving up.
# Default: 3
PAYMENT_VERIFY_RETRIES=3

# Milliseconds to wait between payment verification retries.
# Default: 5000 (5 seconds)
PAYMENT_VERIFY_DELAY_MS=5000


# ── Federation (v0.2 — experimental) ──────────────────────────────────────────
# Comma-separated list of federated peer server URLs (WebSocket).
# Each peer server exposes /federation as a WebSocket endpoint. Users on this
# server can call and DM users on listed peers (and vice versa).
#
# Leave blank for standalone mode (no federation).
#
# Example two-server setup:
#   On v4call.com   → FEDERATION_PEERS=wss://hive-book.com/federation
#   On hive-book.com → FEDERATION_PEERS=wss://v4call.com/federation
FEDERATION_PEERS=

# ── v0.13 — Lobby Notice + Anti-Spam Gate ────────────────
# Custom text shown under the lobby title. Blank = auto-generated from
# SERVER_DOMAIN ("hive-book.com — local lobby. For federated contacts use
# rooms / DMs / calls.")
LOBBY_NOTICE=
# Custom text describing posting requirements. Blank = auto-generated from
# the gate vars below.
LOBBY_REQUIREMENTS_TEXT=
# Minimum *owned, staked* Hive Power to post in the lobby (broadcast or
# encrypted-toggle). Computed from `vesting_shares` × hive_per_vest.
# Set to 0 or leave blank to disable the HP gate. Does not affect DMs or calls.
# (Note: HP is staked HIVE — different from the liquid HIVE balance below.)
LOBBY_POST_MIN_HP=
# Minimum *liquid* HIVE balance to post in the lobby (the spendable balance
# shown in your wallet, not staked HP). Set to 0 or leave blank to disable.
LOBBY_POST_MIN_HIVE=
# Minimum custom Hive-Engine token balance to post. Format: SYMBOL:amount
# (e.g. HIVEBOOK:10). Leave blank to disable the token gate.
LOBBY_POST_MIN_TOKEN=
# How the gates above combine when MORE THAN ONE is set:
# or  = user passes if ANY single threshold is met (default)
# and = user passes only if ALL configured thresholds are met
# Only relevant when 2+ of HP / HIVE / TOKEN gates are set.
LOBBY_POST_GATE_MODE=or

# ─────────────────────────────────────────────────────────────────────────────
# Nostr Federation Discovery (optional — Phase B: server publishes its announce)
# ─────────────────────────────────────────────────────────────────────────────
# How servers discover each other. Does NOT affect the WS federation transport
# (DMs / calls / payments always ride that). Only changes discovery/presence.
#   hive  = old behaviour only (2h Hive blockchain scan), no Nostr
#   nostr = Nostr relays only
#   both  = Nostr (fast) + Hive scan (fallback)  ← recommended default
FED_DISCOVERY_MODE=both
# Comma-separated Nostr relay WebSocket URLs. Include >=1 of your own gated
# relays AND >=2 public relays for redundancy.
NOSTR_RELAYS=wss://nostr.v4call.com,wss://nostr.hive-book.com,wss://relay.damus.io,wss://nos.lol
# Re-publish own announce every N hours (relays drop events; repeat protects).
NOSTR_REPUBLISH_HOURS=6
# OPTIONAL one-time bring-your-own-key seed: paste an existing nsec here on a
# FRESH server to reuse that Nostr identity. It is read ONCE to create
# /app/nostr/nostr-key.json, then ignored. Remove this line after first boot.
# Leave blank to auto-generate a new identity (the normal case).
NOSTR_NSEC=
# Where the identity key file lives inside the container. Must be on the
# ./data/nostr mounted volume (see docker-compose.yml) or it is lost on
# rebuild. Default is correct for the shipped docker-compose; don't change
# unless you know why.
NOSTR_KEY_PATH=/app/nostr/nostr-key.json
# When FED_DISCOVERY_MODE=nostr, should the old 2-hour Hive discovery scan
# still run as a silent safety net? Default true (recommended). Set false ONLY
# for deliberately testing the Nostr-only discovery path in isolation — losing
# the Hive net means a total Nostr relay outage = no new peer discovery.
# Has NO effect when mode is hive or both.
NOSTR_HIVE_FALLBACK=true

# ─────────────────────────────────────────────────────────────────────────────
# Phase D — Cross-server PRESENCE via Nostr (additive to WS federation)
# ─────────────────────────────────────────────────────────────────────────────
# Master gate. When false (default): no presence publish, no presence
# subscribe — Phase B + C unaffected, v4call behaves identically to post-Phase-C.
# When true: this server publishes a throttled snapshot of its online users to
# the Nostr relays, AND listens for other servers' snapshots.
# Trust model: WS-wins-Nostr-additive — Nostr can only ADD users WS hasn't
# yet reported. Nostr never marks anyone offline; WS is authoritative.
FED_PRESENCE_VIA_NOSTR=false
# At most one presence publish per N seconds. Joins/leaves inside the window
# coalesce to a single send at window-end. 30 is a good default.
NOSTR_PRESENCE_THROTTLE_SECONDS=30
# Heartbeat republish every N seconds even if the user list didn't change.
# Protects against relay event drops and proves we're still alive.
NOSTR_PRESENCE_HEARTBEAT_SECONDS=60
# Drop a peer's Nostr presence if we haven't heard a publish in N seconds.
# Default 300 = 5 heartbeats; generous but auto-clears ghosts.
NOSTR_PRESENCE_TTL_SECONDS=300

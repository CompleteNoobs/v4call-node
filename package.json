{
  "name": "v4call-node",
  "version": "0.1.0",
  "description": "Headless v4call server (CLI/API-only) — fed/discovery/presence/routing/chat + HTTP API. Serves no HTML. Succeeds the v4call monolith (v0.16.29).",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js"
  },
  "dependencies": {
    "@hiveio/dhive": "^1.3.2",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "nostr-tools": "^2.7.2",
    "socket.io": "^4.7.5",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "keywords": [
    "hive",
    "blockchain",
    "webrtc",
    "voip",
